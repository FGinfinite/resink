# AI Writing Agent Environment Configuration
# Copy this file to .env and fill in your values
#
# Standalone local debug only.
# 日常开发与部署请优先使用 develop/ 或 deploy/ 的 Compose 编排。

# ===================
# LLM Configuration (SEED ONLY)
# ===================
# ⚠️  These variables are NOT used at runtime.
# LLM model configuration is managed exclusively via MongoDB (aiModelConfigs).
# Use the Admin Panel → AI Model Management to configure models.
#
# These variables are only read by the one-time seed script:
#   node scripts/seed-model-configs.js
# Run it once on first deployment to populate DB from env vars.

# OpenAI compatible API endpoint
OPENAI_API_BASE=https://api.openai.com/v1

# Your API key (required for seed)
OPENAI_API_KEY=sk-your-api-key-here

# Model name
OPENAI_MODEL=gpt-4o

# Max tokens for response
# OPENAI_MAX_TOKENS=4096

# Temperature (0.0 - 2.0)
# OPENAI_TEMPERATURE=0.7

# Request timeout in milliseconds
# OPENAI_TIMEOUT=60000

# Retry attempts on failure
# OPENAI_RETRY_ATTEMPTS=6

# Retry delay between attempts in milliseconds
# OPENAI_RETRY_DELAY=2000

# HTTP proxy for LLM requests (leave empty for direct connection)
# OPENAI_PROXY=http://127.0.0.1:7897

# Max total retry time in ms before giving up
# LLM_MAX_RETRY_TIME_MS=120000

# Max temperature allowed when tool calls are present
# LLM_MAX_TOOL_CALL_TEMPERATURE=0.5

# ===================
# LLM Streaming Limits
# ===================

# Max buffer size for streaming response chunks (bytes)
# LLM_STREAM_MAX_BUFFER_CHARS=524288

# Max total content chars in a single streaming response
# LLM_STREAM_MAX_CONTENT_CHARS=2097152

# Max tool arguments chars in a single streaming response
# LLM_STREAM_MAX_TOOL_ARGS_CHARS=524288

# ============================
# Tab Autocomplete (FIM)
# ============================
# LLM connection settings (apiBase/apiKey/model etc.) are managed via
# MongoDB featureBindings in Admin Panel. These non-LLM parameters are still
# read directly from env vars at runtime.

# Number of characters to include before/after cursor as context
# AUTOCOMPLETE_PREFIX_CHARS=2000
# AUTOCOMPLETE_SUFFIX_CHARS=500

# Project context settings for autocomplete
# AUTOCOMPLETE_CONTEXT_MAX_CHARS=4000
# AUTOCOMPLETE_CONTEXT_MAX_FILES=5
# AUTOCOMPLETE_CONTEXT_CACHE_TTL=10000
# AUTOCOMPLETE_CONTEXT_CACHE_MAX=200

# Reasoning model controls
# Send disable_reasoning:true in LLM request (for Cerebras GLM-style models)
# AUTOCOMPLETE_DISABLE_REASONING=true
# Use max_completion_tokens instead of max_tokens (for reasoning models where
# max_tokens includes thinking tokens). Set to desired output token limit.
# AUTOCOMPLETE_MAX_COMPLETION_TOKENS=128

# Request validation limits
# AUTOCOMPLETE_MAX_PREFIX_LENGTH=50000
# AUTOCOMPLETE_MAX_SUFFIX_LENGTH=50000
# AUTOCOMPLETE_MAX_FILENAME_LENGTH=500
# AUTOCOMPLETE_MIN_PREFIX_LENGTH=10
# AUTOCOMPLETE_MAX_SURROUNDING_CONTEXT=20000

# Rate limiting (per user)
# AUTOCOMPLETE_RATE_LIMIT_WINDOW_MS=60000
# AUTOCOMPLETE_RATE_LIMIT_MAX=60

# ============================
# Autocomplete Digest
# ============================
# Digest generates document summaries to enrich autocomplete context.
# LLM connection is managed via MongoDB featureBindings (digestModel).

# AUTOCOMPLETE_DIGEST_MAX_TOKENS=800

# Cache settings
# AUTOCOMPLETE_DIGEST_ABSOLUTE_EXPIRY_MS=1800000
# AUTOCOMPLETE_DIGEST_CACHE_MAX_SIZE=100

# Content thresholds for digest generation
# AUTOCOMPLETE_DIGEST_MIN_DOC_CHARS=1000
# AUTOCOMPLETE_DIGEST_MIN_OUTLINE_CHARS=3000
# AUTOCOMPLETE_DIGEST_GLOBAL_SUMMARY_MAX_CHARS=2000
# AUTOCOMPLETE_DIGEST_SECTION_TITLE_MAX_LENGTH=200
# AUTOCOMPLETE_DIGEST_SECTION_DESC_MAX_LENGTH=1000

# ===================
# Quick Edit
# ===================

# Rate limiting (per user)
# QUICK_EDIT_RATE_LIMIT_WINDOW_MS=60000
# QUICK_EDIT_RATE_LIMIT_MAX=30

# Input limits
# QUICK_EDIT_MAX_SELECTION_LENGTH=10000
# QUICK_EDIT_MAX_SURROUNDING_CONTEXT=20000

# Token limits
# QUICK_EDIT_MAX_TOKENS=4096
# QUICK_EDIT_MIN_TOKENS=256

# ===================
# Service Configuration
# ===================

# Listen address and port
# For local standalone use, 127.0.0.1 is fine.
# If Web runs in Docker via develop/, ai-writing-agent must listen on 0.0.0.0
# so host.docker.internal can reach it from the web container.
LISTEN_ADDRESS=127.0.0.1
PORT=3060

# Graceful shutdown timeout in ms
# SHUTDOWN_TIMEOUT_MS=10000

# ===================
# Security
# ===================

# Shared secret for proxy authentication (required in production)
# In local develop/ mode, this must match develop/dev.env
# AI_PROXY_SECRET=dev-ai-proxy-secret

# ===================
# MongoDB Configuration
# ===================

# Full connection string (takes priority over MONGO_HOST)
# MONGO_CONNECTION_STRING=mongodb://localhost/sharelatex

# MongoDB host (used when MONGO_CONNECTION_STRING is not set)
# MONGO_HOST=127.0.0.1

# Enable MongoDB command monitoring
# MONGO_MONITOR_COMMANDS=true

# ===================
# Internal Services
# ===================

# DOCUMENT_UPDATER_HOST=127.0.0.1
# DOCUMENT_UPDATER_PORT=3003
# WEB_HOST=127.0.0.1
# WEB_PORT=3000

# Web API authentication (used for internal service-to-service calls)
# WEB_API_USER=overleaf
# WEB_API_PASSWORD=overleaf

# ===================
# Agent Limits
# ===================

# AGENT_MAX_TURNS=10
# AGENT_MAX_TOOL_CALLS=20
# AGENT_SESSION_TIMEOUT=1800000

# Max delegate_task nesting depth
# AGENT_DEPTH_LIMIT=20

# Estimated characters per token for budget tracking
# AGENT_ESTIMATED_CHARS_PER_TOKEN=4

# Default tool execution timeout in ms
# AGENT_TOOL_TIMEOUT_MS=60000

# ===================
# Run Budget (per-request limits)
# ===================

# Max wall time in ms, excluding user confirmation wait time (default: 5 min)
# RUN_BUDGET_MAX_WALL_TIME_MS=300000

# Max LLM calls per request
# RUN_BUDGET_MAX_LLM_CALLS=30

# Max tool calls per request
# RUN_BUDGET_MAX_TOOL_CALLS=70

# Max total tokens per request
# RUN_BUDGET_MAX_TOTAL_TOKENS=200000

# Max delegate_task nesting depth
# RUN_BUDGET_MAX_DEPTH=1

# Max delegate_task invocations
# RUN_BUDGET_MAX_DELEGATIONS=6

# ===================
# AI Assistant (SSE / Session / Rate Limits)
# ===================

# SSE streaming
# AI_MAX_SSE_QUEUE=200
# AI_BACKPRESSURE_LIMIT=50
# AI_DRAIN_TIMEOUT_MS=5000

# Session management
# AI_SESSION_PAGE_SIZE=200
# AI_SESSION_PAGE_MAX=500
# AI_MAX_CHANGE_HISTORY=200
# AI_MAX_MESSAGE_CHARS=2000000
# AI_MAX_SESSION_TITLE_LENGTH=200
# AI_MAX_CONCURRENT_SESSIONS=3

# Agent limits
# AI_MAX_SELECTION_REFERENCES=20
# AI_MAX_SELECTION_CHARS=16000

# Prompt sanitization
# AI_MAX_PROMPT_INLINE_LENGTH=200
# AI_MAX_PROMPT_BLOCK_LENGTH=10000

# Rate limiting (per user)
# AI_MESSAGE_RATE_MAX=60
# AI_MESSAGE_RATE_WINDOW_MS=60000
# AI_UPLOAD_RATE_MAX=20
# AI_UPLOAD_RATE_WINDOW_MS=60000

# Streaming context
# AI_STREAMING_CONTEXT_MAX_ITEMS=200

# Attachment TTL (unreferenced: 24h, referenced: 3d)
# AI_UNREFERENCED_ATTACHMENT_TTL_MS=86400000
# AI_REFERENCED_ATTACHMENT_TTL_MS=259200000

# Change lock TTL for concurrent edit protection
# AI_CHANGE_LOCK_TTL_MS=120000

# ===================
# Confirmation Channel
# ===================

# Timeout for a single pending change confirmation in ms (default: 30 min)
# CONFIRMATION_TIMEOUT_MS=1800000

# Max pending confirmations
# CONFIRMATION_MAX_PENDING=500

# Default timeout for ConfirmationChannel waitForConfirmation
# CONFIRMATION_DEFAULT_TIMEOUT_MS=1800000

# Max early (pre-registered) confirmations stored
# CONFIRMATION_MAX_EARLY=100

# TTL for early confirmation entries in ms
# CONFIRMATION_EARLY_TTL_MS=30000

# TTL for finalized (accepted/rejected) confirmations in ms
# CONFIRMATION_FINALIZED_TTL_MS=60000

# ===================
# Document Limits
# ===================

# Max lines returned when reading a document (list/display)
# DOCUMENT_MAX_LINES=1000

# Max characters returned when reading a document
# DOCUMENT_MAX_CHARS=50000

# Max content length accepted for document operations
# DOCUMENT_MAX_CONTENT_LENGTH=100000

# Document content cache size
# DOCUMENT_CONTENT_CACHE_SIZE=50

# Max lines for read_document tool
# DOCUMENT_MAX_READ_LINES=2000

# Max chars for delete preview content
# DOCUMENT_DELETE_PREVIEW_MAX_CHARS=50000

# Max entries in document outline
# DOCUMENT_OUTLINE_MAX_ENTRIES=30

# ===================
# Document Edit (Replacer)
# ===================

# Anchor text length for edit position matching
# DOCUMENT_EDIT_ANCHOR_LENGTH=100

# Max retries for edit position resolution
# DOCUMENT_EDIT_MAX_RETRIES=1

# Max character shift when searching for edit position
# DOCUMENT_EDIT_MAX_SHIFT=500

# Disambiguation ratio for overlapping edit candidates
# DOCUMENT_EDIT_DISAMBIGUATION_RATIO=2.0

# Max oldText/newText length in edit operations
# DOCUMENT_EDIT_MAX_OLD_TEXT_LENGTH=102400
# DOCUMENT_EDIT_MAX_NEW_TEXT_LENGTH=102400

# API timeout for document-updater calls
# DOCUMENT_EDIT_API_TIMEOUT_MS=30000

# ===================
# Project Cache
# ===================

# Max entities in project structure cache
# PROJECT_ENTITY_CACHE_MAX=500

# Project structure cache TTL in ms
# PROJECT_ENTITY_CACHE_TTL_MS=300000

# ===================
# Project Access Control
# ===================

# Access check cache TTL (project-access util)
# PROJECT_ACCESS_CACHE_TTL_MS=10000

# Access check cache TTL (AgentController level)
# PROJECT_ACCESS_CONTROLLER_CACHE_TTL_MS=60000

# HTTP request timeout for access verification
# PROJECT_ACCESS_REQUEST_TIMEOUT_MS=5000

# Cache cleanup thresholds (trigger cleanup / force full sweep)
# PROJECT_ACCESS_CACHE_CLEANUP_THRESHOLD=5000
# PROJECT_ACCESS_CACHE_FORCE_CLEANUP_THRESHOLD=20000

# Rate limit map cleanup thresholds
# PROJECT_ACCESS_RATE_MAP_CLEANUP_THRESHOLD=10000
# PROJECT_ACCESS_RATE_MAP_FORCE_CLEANUP_THRESHOLD=20000

# ===================
# FileStore Adapter
# ===================

# Max upload size in bytes (default: 5MB)
# FILESTORE_UPLOAD_MAX_SIZE=5242880

# Max download size in bytes (default: 5MB)
# FILESTORE_DOWNLOAD_MAX_SIZE=5242880

# Request timeout in ms
# FILESTORE_TIMEOUT_MS=60000

# ===================
# Search Configuration
# ===================

# Max search results returned
# SEARCH_MAX_RESULTS=50

# Lines of context shown around each search match (default display)
# SEARCH_DEFAULT_CONTEXT_LINES=2

# Max context lines for search_project tool
# SEARCH_MAX_CONTEXT_LINES=20

# Max pattern length for search queries
# SEARCH_MAX_PATTERN_LENGTH=500

# Max bytes to scan across all files
# SEARCH_MAX_SCAN_BYTES=2000000

# Max files to include in search
# SEARCH_MAX_FILES=200

# Max individual file size to search
# SEARCH_MAX_FILE_SIZE=500000

# Max line length before truncation in results
# SEARCH_MAX_LINE_LENGTH=2000

# ===================
# List Tool
# ===================

# Max glob pattern length
# LIST_MAX_PATTERN_LENGTH=200

# Max files for line count computation
# LIST_LINE_COUNT_MAX_FILES=50

# ===================
# Deep Review
# ===================

# REVIEW_MAX_TURNS=15
# REVIEW_MAX_TOOL_CALLS=30
# REVIEW_SUB_AGENT_MAX_TOKENS=8192
# REVIEW_SUB_AGENT_TEMPERATURE=0.3

# ===================
# Memory (Project Rules)
# ===================

# Max character length for project rules content
# MEMORY_MAX_RULES_LENGTH=10000

# Max tool context items in memory
# MEMORY_MAX_TOOL_CONTEXT_ITEMS=200

# Max summary length
# MEMORY_SUMMARY_MAX_LENGTH=8000

# Max inline name length in context
# MEMORY_MAX_INLINE_NAME_LENGTH=200

# Max image attachments included in history
# MEMORY_MAX_HISTORY_ATTACHMENTS=20

# Max messages included in history context
# MEMORY_MAX_HISTORY_MESSAGES=50

# Max total context length in chars
# MEMORY_MAX_CONTEXT_LENGTH=100000

# ===================
# Image / Multimodal
# ===================
# supportsImage is now per-model-config (managed in Admin Panel DB).

# Max image upload size in bytes (default: 5MB)
# IMAGE_MAX_SIZE=5242880

# Max project file download size (0 = unlimited)
# PROJECT_FILE_MAX_SIZE=0

# ============================
# External Academic APIs
# ============================

# Semantic Scholar (https://www.semanticscholar.org/)
# SEMANTIC_SCHOLAR_API_KEY=
# SEMANTIC_SCHOLAR_BASE_URL=https://api.semanticscholar.org/graph/v1

# CrossRef (https://www.crossref.org/)
# Polite pool: set your email for faster rate limits
# CROSSREF_EMAIL=
# CROSSREF_BASE_URL=https://api.crossref.org

# arXiv (https://arxiv.org/)
# ARXIV_BASE_URL=https://export.arxiv.org/api

# Shared settings for all external API calls
# EXTERNAL_API_TIMEOUT=10000
# EXTERNAL_API_MAX_RETRIES=2
# EXTERNAL_API_RETRY_AFTER_CAP_SECONDS=30
# EXTERNAL_API_MAX_RESPONSE_BYTES=5242880

# bib_lookup field truncation limits
# BIB_LOOKUP_DEFAULT_LIMIT=5
# BIB_LOOKUP_MAX_LIMIT=20
# BIB_LOOKUP_MAX_TITLE_LENGTH=300
# BIB_LOOKUP_MAX_AUTHOR_LENGTH=100
# BIB_LOOKUP_MAX_ABSTRACT_LENGTH=1500
# BIB_LOOKUP_MAX_VENUE_LENGTH=200

# ===================
# Skill System
# ===================

# SKILL_MAX_BODY_LENGTH=32768
# SKILL_MAX_NAME_LENGTH=64
# SKILL_MAX_DESCRIPTION_LENGTH=256
# SKILL_MAX_TRIGGER_HINT_LENGTH=256

# ===================
# Agent Type System
# ===================

# AGENT_TYPE_MAX_TURNS_LIMIT=50
# AGENT_TYPE_MAX_TOOLS_PER_AGENT=20
# AGENT_TYPE_MAX_BODY_LENGTH=32768
# AGENT_TYPE_MAX_NAME_LENGTH=64
# AGENT_TYPE_MAX_DESCRIPTION_LENGTH=256

# ===================
# Replacer (Fuzzy Matching)
# ===================

# Max string length for Levenshtein distance computation
# REPLACER_MAX_LEVENSHTEIN_LENGTH=5000

# ===================
# Context Compaction
# ===================

# Enable/disable automatic context compaction (default: true)
# COMPACTION_ENABLED=true

# Model's context window size in tokens (default: 131072)
# CONTEXT_WINDOW=131072

# Trigger compaction when prompt tokens reach this ratio of context window (default: 0.7)
# COMPACTION_THRESHOLD=0.7

# Max tokens for the generated summary (default: 2048)
# COMPACTION_SUMMARY_MAX_TOKENS=2048

# Trigger compaction when message count exceeds this threshold (default: 30)
# COMPACTION_MESSAGE_THRESHOLD=30
